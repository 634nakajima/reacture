{
  "name": "reacture-desktop",
  "version": "0.1.0",
  "description": "Reacture desktop overlay - reactions and comments on top of any app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.reacture.desktop",
    "productName": "Reacture Desktop",
    "mac": {
      "category": "public.app-category.education",
      "icon": "../public/logo.png",
      "target": "dir"
    },
    "files": [
      "main.js",
      "preload.js",
      "setup.html",
      "setup.js",
      "overlay.html",
      "overlay.js",
      "overlay.css",
      "qr-window.html",
      "poll-window.html",
      "sounds/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../public/logo.png",
        "to": "logo.png"
      }
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  }
}
